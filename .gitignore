# pyenv
#   For a library or app, you might want to share your .python-version.
#   Only uncomment if you are using pyenv.
#.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in git.
#   However, in case of collaboration, if used, it should be kept.
#   For now, we'll let it be.

# poetry
#   Similar to Pipenv, poetry.lock is generally recommended to be committed.
#   pyproject.toml is definitely committed.

# pdm
#   Similar to Poetry and Pipenv, pdm.lock is generally recommended to be committed.
.pdm-python
.pdm-build/

# pipx
.pipx/

